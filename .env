# Render sets PORT automatically for Web Services. Keep this only for local runs.
PORT=10000

# Build-time image pin. Render also exposes service env vars as Docker build args.
CONSUL_VERSION=2.0.0

# Consul runtime configuration.
CONSUL_NODE_NAME=render-consul
CONSUL_DATACENTER=dc1
CONSUL_DOMAIN=consul
CONSUL_LOG_LEVEL=INFO
CONSUL_BOOTSTRAP_EXPECT=1
CONSUL_UI=true

# Security. Set a strong random UUID/string in Render secrets before going public.
CONSUL_ACL_ENABLED=true
CONSUL_ACL_DEFAULT_POLICY=deny
CONSUL_ACL_INITIAL_MANAGEMENT_TOKEN=

# Optional ports for internal container interfaces. Render will expose only the HTTP PORT.
CONSUL_DNS_PORT=8600
CONSUL_GRPC_PORT=8502
CONSUL_GRPC_TLS_PORT=8503
